{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "stashbackend"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
"apphosting": [
  {
    "backendId": "stashbackend",
    "appId": "1:619754582329:web:04e99d7aa961f9c1c778e8",
    "rootDir": "backend"
  }
],
  "storage": {
    "rules": "storage.rules"
  }
}